// prisma/schema.prisma
// Database Schema for HOME NET Transport
// For local development and out-of-the-box working preview, it uses SQLite.
// To deploy to Neon PostgreSQL in production, change the datasource provider to "postgresql" and set DATABASE_URL in .env.

// datasource db {
//   provider = "sqlite"
//   url      = "file:./dev.db"
// }
datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  role          String   // "SUPER_ADMIN", "BUREAU", "CHAUFFEUR"
  licenseNumber String?  // For chauffeurs
  licenseExpiry String?  // For chauffeurs, e.g. "2028-12-31"
  status        String   @default("ACTIVE") // "ACTIVE", "INACTIVE"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  assignedRides        Ride[]         @relation("ChauffeurRides")
  assignedRecurring    RecurringReservation[] @relation("ChauffeurRecurring")
  notifications        Notification[]
  logs                 ActivityLog[]
}

model Client {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  phone        String
  email        String?   @unique
  address      String
  city         String
  postalCode   String
  isPmr        Boolean  @default(false)
  observations String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  rides                 Ride[]
  recurringReservations RecurringReservation[]
  invoices              Invoice[]
}

model Vehicle {
  id                    String   @id @default(uuid())
  registrationNumber    String   @unique // Immatriculation
  brand                 String   // Ford, Renault, Toyota, etc.
  model                 String   // Rifter, Proace, etc.
  type                  String   // "PMR", "Standard", etc.
  mileage               Float    // Kilométrage actuel
  insuranceDate         String   // yyyy-mm-dd
  technicalInspectionDate String // yyyy-mm-dd
  status                String   @default("AVAILABLE") // "AVAILABLE", "IN_SERVICE", "MAINTENANCE"
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  rides                 Ride[]
  recurringReservations RecurringReservation[]
}

model Ride {
  id                     String   @id @default(uuid())
  rideNumber             String   @unique // e.g. TR-1001
  clientId               String
  client                 Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date                   String   // yyyy-mm-dd
  time                   String   // hh:mm
  departureAddress       String
  arrivalAddress         String
  chauffeurId            String?
  chauffeur              User?    @relation("ChauffeurRides", fields: [chauffeurId], references: [id], onDelete: SetNull)
  vehicleId              String?
  vehicle                Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  isPmr                  Boolean  @default(false)
  notes                  String?  // Remarque
  status                 String   @default("PLANNED") // "PLANNED", "CONFIRMED", "IN_PROGRESS", "COMPLETED", "CANCELLED"
  realMileage            Float?   // Kilometer completed (entered by chauffeur)
  recurringReservationId String?
  recurringReservation   RecurringReservation? @relation(fields: [recurringReservationId], references: [id], onDelete: SetNull)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relations
  invoices               Invoice[]
}

model RecurringReservation {
  id               String   @id @default(uuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  startRideDate    String   // yyyy-mm-dd
  startTime        String   // hh:mm
  departureAddress String
  arrivalAddress   String
  chauffeurId      String?
  chauffeur        User?    @relation("ChauffeurRecurring", fields: [chauffeurId], references: [id], onDelete: SetNull)
  vehicleId        String?
  vehicle          Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  isPmr            Boolean  @default(false)
  notes            String?
  frequency        String   // "DAILY", "WEEKLY", "MONTHLY"
  untilDate        String   // yyyy-mm-dd
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  rides            Ride[]
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique // e.g. FAC-2026-0001
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date          String   // yyyy-mm-dd
  amount        Float
  status        String   @default("UNPAID") // "UNPAID", "PAID"
  rideId        String?
  ride          Ride?    @relation(fields: [rideId], references: [id], onDelete: SetNull)
  month         String?  // e.g. "2026-06" (for monthly billing)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Notification {
  id          String   @id @default(uuid())
  recipientId String
  recipient   User     @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  title       String
  message     String
  type        String   // "RIDE_ASSIGNED", "RIDE_UPDATED", "RIDE_CANCELLED", "REMINDER"
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g., "CONNEXION", "CREATION_TRAJET", "MODIFICATION_CLIENT"
  details   String
  createdAt DateTime @default(now())
}
